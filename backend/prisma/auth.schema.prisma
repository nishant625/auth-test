generator client {
  provider = "prisma-client-js"
  output   = "../generated/auth-client"
}

datasource db {
  provider = "postgresql"
  url      = env("AUTH_DATABASE_URL")
}

model Token {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  clientId  String
  scope     String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
